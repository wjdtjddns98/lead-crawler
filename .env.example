# lead-crawler 환경설정 예시 — 실제 값은 .env 에 두고 커밋하지 말 것.

# 기본 동작: dry_run=true 면 외부 호출 없이 결정적 시뮬레이션으로 동작.
LEADCRAWLER_DRY_RUN=true

# PostgreSQL 연결 (db extra 설치 후 사용)
LEADCRAWLER_DATABASE_URL=postgresql+psycopg://leadcrawler:leadcrawler@localhost:5432/leadcrawler

# 발견 소스 키 (없으면 해당 소스 비활성/no-op)
LEADCRAWLER_EDGAR_USER_AGENT=Zenith Asset zenithasset@naver.com
LEADCRAWLER_DART_API_KEY=
LEADCRAWLER_COMPANIES_HOUSE_API_KEY=
LEADCRAWLER_OPENCORPORATES_API_KEY=

# 검색엔진 발견
LEADCRAWLER_GOOGLE_CSE_KEY=
LEADCRAWLER_GOOGLE_CSE_CX=
LEADCRAWLER_BING_API_KEY=

# 이메일 보강/검증
LEADCRAWLER_HUNTER_API_KEY=
LEADCRAWLER_APOLLO_API_KEY=
LEADCRAWLER_ZEROBOUNCE_API_KEY=
LEADCRAWLER_NEVERBOUNCE_API_KEY=

# AI (Claude Vision 이미지 이메일 판독)
LEADCRAWLER_ANTHROPIC_API_KEY=

# 운영비 한도 (월, 원). cost_ledger 경고 기준.
LEADCRAWLER_MONTHLY_BUDGET_KRW=500000
