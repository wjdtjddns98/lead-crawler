# lead-crawler 환경설정 예시 — 실제 값은 .env 에 두고 커밋하지 말 것.

# 기본 동작: dry_run=true 면 외부 호출 없이 결정적 시뮬레이션으로 동작.
LEADCRAWLER_DRY_RUN=true

# PostgreSQL 연결 (운영/로컬 — docker compose up 후 alembic upgrade head)
LEADCRAWLER_DATABASE_URL=postgresql+psycopg://leadcrawler:leadcrawler@localhost:5432/leadcrawler
# 도커 없이 빠르게 테스트하려면 파일 SQLite 로 대체 가능(스키마 양립):
# LEADCRAWLER_DATABASE_URL=sqlite:///./dev.db

# 발견 소스 키 (없으면 해당 소스 비활성/no-op)
# EDGAR 정책상 식별 가능한 UA 필요(실제 값은 .env 에). 예: "회사명 you@example.com"
LEADCRAWLER_EDGAR_USER_AGENT=__YOUR_ORG__ you@example.com
LEADCRAWLER_DART_API_KEY=
LEADCRAWLER_COMPANIES_HOUSE_API_KEY=
LEADCRAWLER_OPENCORPORATES_API_KEY=

# 검색엔진 발견
LEADCRAWLER_GOOGLE_CSE_KEY=
LEADCRAWLER_GOOGLE_CSE_CX=
LEADCRAWLER_BING_API_KEY=

# 이메일 보강/검증
LEADCRAWLER_HUNTER_API_KEY=
LEADCRAWLER_APOLLO_API_KEY=
LEADCRAWLER_ZEROBOUNCE_API_KEY=
LEADCRAWLER_NEVERBOUNCE_API_KEY=

# AI (Claude Vision 이미지 이메일 판독)
LEADCRAWLER_ANTHROPIC_API_KEY=

# 운영비 한도 (월, 원). cost_ledger 경고 기준.
LEADCRAWLER_MONTHLY_BUDGET_KRW=500000

# Notion 자동 리포팅 (토큰 없으면 no-op — payload 만 생성). 통합 시크릿을 각 DB 에 공유 필요.
LEADCRAWLER_NOTION_TOKEN=

# 24/7 스케줄러 (매일 크롤 1회전 + Notion 일일보고·스크럼·현황 자동 기입)
# 활성화하려면 true + `pip install -e .[schedule]`(APScheduler). serve 명령으로 기동.
LEADCRAWLER_SCHEDULER_ENABLED=false
LEADCRAWLER_REPORT_HOUR=0       # 실행 시각(UTC 시) — 0=매일 09:00 KST
LEADCRAWLER_REPORT_MINUTE=0
LEADCRAWLER_REPORT_INDUSTRIES=건설   # 쉼표구분(예: 건설,반도체)
LEADCRAWLER_REPORT_COUNTRIES=KR      # 쉼표구분(빈값=지원 전체국)
LEADCRAWLER_REPORT_MILESTONE=M3
LEADCRAWLER_REPORT_PERSIST=false     # 일일 잡 결과 DB 영속화
